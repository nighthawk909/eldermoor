diff --git a/src/gating.js b/src/gating.js
new file mode 100644
index 0000000..ae89c7f
--- /dev/null
+++ b/src/gating.js
@@ -0,0 +1,205 @@
+/* =====================================================================
+   ELDERMOOR - tutorial gating (FLOW2/GATE).
+
+   Exposes window.EMGATING = { canDo(targetId), nudge(targetId), lockedZones() }.
+   Reads tutorial progress from window.EMLESSON.current() and the ordered
+   L0-L17 lesson sequence (instructor ids + zone ids) to decide whether a
+   player interaction is allowed yet.
+
+   canDo(npcOrZoneId) -> true when the target is the current/already-done step,
+                         false when it is still locked.
+   nudge(targetId)    -> shows an OSRS-style chat hint via EMHUD.addChat and
+                         returns false (convenience: call inside interact guards).
+   lockedZones()      -> array of zone ids not yet reachable.
+
+   Listens to the 'em-lesson' event so the gating map refreshes automatically
+   whenever the lesson state advances.
+
+   Self-contained and defensive: no-ops cleanly when EMLESSON or EMHUD are
+   absent (headless / pre-boot environments). No mutation of external state.
+   ===================================================================== */
+
+/* ------------------------------------------------------------------ helpers */
+function hud() {
+  return (typeof window !== "undefined" && window.EMHUD) ? window.EMHUD : null;
+}
+
+function lesson() {
+  if (typeof window === "undefined" || !window.EMLESSON) return null;
+  try { return window.EMLESSON.current(); } catch (e) { return null; }
+}
+
+/* Return the ordered lesson array from EMDATA, falling back to the static
+   inline table built from lessons.json at authoring time.  The inline table
+   is intentionally kept in sync with assets/data/lessons.json (L0-L17). */
+function lessonList() {
+  const d = (typeof window !== "undefined") ? window.EMDATA : null;
+  const list = d && d.lessons;
+  if (Array.isArray(list)) return list;
+  if (list && Array.isArray(list.lessons)) return list.lessons;
+  return STATIC_LESSONS;
+}
+
+/* Collect every id (instructor + zone) that belongs to lesson i and beyond. */
+function idsForIndex(i) {
+  const ls = lessonList();
+  const ids = new Set();
+  for (let j = i; j < ls.length; j++) {
+    const l = ls[j];
+    if (!l) continue;
+    if (l.instructor) ids.add(String(l.instructor).toLowerCase());
+    if (l.zone) ids.add(String(l.zone).toLowerCase());
+    if (l.id) ids.add(String(l.id).toLowerCase());
+  }
+  return ids;
+}
+
+/* --------------------------------------------------------- inline fallback */
+/* Mirrors assets/data/lessons.json so the module works even before EMDATA
+   loads.  Kept minimal: only the fields we query (id, instructor, zone). */
+const STATIC_LESSONS = [
+  { id: "L0",  instructor: "halric", zone: "spawn_house" },
+  { id: "L1",  instructor: "halric", zone: "spawn_house" },
+  { id: "L2",  instructor: "maeve",  zone: "survival" },
+  { id: "L3",  instructor: "maeve",  zone: "survival" },
+  { id: "L4",  instructor: "maeve",  zone: "survival" },
+  { id: "L5",  instructor: "maeve",  zone: "survival" },
+  { id: "L6",  instructor: "tobin",  zone: "cooks_house" },
+  { id: "L7",  instructor: "edda",   zone: "spawn_house" },
+  { id: "L8",  instructor: "doran",  zone: "mine" },
+  { id: "L9",  instructor: "doran",  zone: "mine" },
+  { id: "L10", instructor: "doran",  zone: "mine" },
+  { id: "L11", instructor: "vael",   zone: "combat" },
+  { id: "L12", instructor: "vael",   zone: "combat" },
+  { id: "L13", instructor: "wynn",   zone: "bank" },
+  { id: "L14", instructor: "brann",  zone: "bank" },
+  { id: "L15", instructor: "aldric", zone: "chapel" },
+  { id: "L16", instructor: "sorrel", zone: "wizard" },
+  { id: "L17", instructor: "halric", zone: "dock" }
+];
+
+/* --------------------------------------------------------- current state */
+/* Derive a snapshot of gating state from EMLESSON.current(). Returns a plain
+   object so callers never hold a mutable reference into lesson internals. */
+function state() {
+  const snap = lesson();
+  if (!snap) {
+    // EMLESSON not present yet - treat everything as allowed (fail-open).
+    return { lessonIndex: 0, completed: [], done: false };
+  }
+  const ls = lessonList();
+  const lessonId = snap.lessonId || (snap.lesson && snap.lesson.id) || null;
+  let lessonIndex = snap.progress ? snap.progress.lessonIndex : 0;
+  if (typeof lessonIndex !== "number" || lessonIndex < 0) lessonIndex = 0;
+
+  // completed is an array of lesson ids already finished.
+  const completed = Array.isArray(snap.completed) ? snap.completed.slice() : [];
+
+  return { lessonIndex, completed, done: !!snap.done, lessonId, ls };
+}
+
+/* --------------------------------------------------------- public helpers */
+/* Given a target id (instructor name, zone id, or lesson id) decide if it is
+   currently accessible: it is accessible when its first lesson in the chain
+   is at or before the current lesson (or the tutorial is done). */
+function canDo(targetId) {
+  if (!targetId) return true;           // no id supplied -> don\'t gate
+  const key = String(targetId).toLowerCase();
+  const s = state();
+
+  if (s.done) return true;             // tutorial finished -> open world
+
+  const ls = lessonList();
+
+  // Walk the lesson list and find the earliest lesson that involves this id.
+  let firstLessonIndex = -1;
+  for (let i = 0; i < ls.length; i++) {
+    const l = ls[i];
+    if (!l) continue;
+    const matchInstructor = l.instructor && String(l.instructor).toLowerCase() === key;
+    const matchZone = l.zone && String(l.zone).toLowerCase() === key;
+    const matchId = l.id && String(l.id).toLowerCase() === key;
+    if (matchInstructor || matchZone || matchId) {
+      firstLessonIndex = i;
+      break;
+    }
+  }
+
+  if (firstLessonIndex === -1) return true;  // unknown id - don\'t gate it
+
+  // The target is available when the player has reached or passed its lesson.
+  return firstLessonIndex <= s.lessonIndex;
+}
+
+/* Show an OSRS-style hint pointing to the current instructor.  Returns false
+   so callers can do: if (!EMGATING.canDo(id)) return EMGATING.nudge(id); */
+function nudge(targetId) {
+  const h = hud();
+  if (!h || typeof h.addChat !== "function") return false;
+
+  const s = state();
+  if (s.done) return false;
+
+  const ls = lessonList();
+  const current = ls[s.lessonIndex];
+  if (!current) return false;
+
+  const who = current.instructor
+    ? capitalize(current.instructor)
+    : "your current instructor";
+
+  h.addChat("You should speak to " + who + " first.", "", true);
+  return false;
+}
+
+/* Return an array of zone ids that the player has not yet unlocked. */
+function lockedZones() {
+  const s = state();
+  if (s.done) return [];
+
+  const ls = lessonList();
+  const locked = [];
+  for (let i = s.lessonIndex + 1; i < ls.length; i++) {
+    const l = ls[i];
+    if (l && l.zone) {
+      const z = String(l.zone).toLowerCase();
+      if (!locked.includes(z)) locked.push(z);
+    }
+  }
+  return locked;
+}
+
+/* ----------------------------------------------------------------- utils */
+function capitalize(s) {
+  return s ? s.charAt(0).toUpperCase() + s.slice(1) : s;
+}
+
+/* -------------------------------------------------------- event wiring */
+function onLessonEvent() {
+  // The gating functions re-read EMLESSON.current() on every call, so no
+  // cached state needs to be flushed here.  The listener exists so external
+  // code can hook 'em-lesson' knowing gating is always in sync.
+  // (intentionally a no-op - present for future extension and documentation)
+}
+
+/* ------------------------------------------------------ public entry point */
+export function initGating() {
+  if (typeof window !== "undefined") {
+    window.addEventListener("em-lesson", onLessonEvent);
+    window.addEventListener("em-data-ready", onLessonEvent);
+  }
+
+  const api = {
+    canDo,
+    nudge,
+    lockedZones
+  };
+
+  if (typeof window !== "undefined") {
+    window.EMGATING = api;
+  }
+
+  return api;
+}
+
+export default initGating;
