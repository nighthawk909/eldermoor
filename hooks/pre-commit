#!/bin/sh
# Eldermoor pre-commit gates — block broken/incomplete commits. core.hooksPath=hooks installs it.
echo "[pre-commit] gates: smoke + tests + parity…"
npm run smoke   || { echo "[pre-commit] BLOCKED: smoke check failed."; exit 1; }
npm test        || { echo "[pre-commit] BLOCKED: tests failed."; exit 1; }
npm run parity  || { echo "[pre-commit] BLOCKED: parity gate failed (a feature marked Done has an unfinished parity checklist)."; exit 1; }
echo "[pre-commit] ok."
exit 0
